# Database (Supabase or local Postgres)
# Option 1: Full URL (Supabase: use connection string from project settings)
# DATABASE_URL=postgres://user:password@host:5432/database

# Option 2: Individual fields (local dev)
# DATABASE_HOST=localhost
# DATABASE_USERNAME=vapor_username
# DATABASE_PASSWORD=vapor_password
# DATABASE_NAME=vapor_database
# DATABASE_PORT=5432

DATABASE_URL=
# Dev only: skip TLS cert verification (e.g. Supabase on macOS with cert issues)
DATABASE_INSECURE_TLS=

# CORS (frontend origin for credentials)
CORS_ORIGIN=http://localhost:3000

# Public app URL (no trailing slash). Used for Stripe/billing redirects and OAuth defaults; also used as CORS fallback in configure.swift.
# FRONTEND_URL=http://localhost:3000

# GitHub OAuth (GITHUB_OAUTH_REDIRECT_URI is required — no localhost default)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# SaaS: webhook creation (base URL for webhook delivery)
WEBHOOK_BASE_URL=http://localhost:8080

# SaaS: token encryption (32 bytes base64; generate with: openssl rand -base64 32).
# Required for GitHub OAuth/App signed state (return_to survives without sticky sessions).
ENCRYPTION_KEY=

# Optional fallback for repo fetch when no OAuth token
# GITHUB_TOKEN=

# Stripe (Pro billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# Optional legacy monthly fallback if MONTHLY unset:
# STRIPE_PRICE_PRO=price_...

# Checkout / portal success URLs: set FRONTEND_URL or CORS_ORIGIN (billing requires one of them)

# MCP tenant host: {subdomain}.{SAAS_MCP_BASE_DOMAIN} for Host ↔ project binding (no scheme)
# SAAS_MCP_BASE_DOMAIN=mcp.example.com
#
# Public MCP URL shown in API (`mcp_url` on Project): scheme + host + path
# SAAS_MCP_URL_SCHEME=https
# SAAS_MCP_PATH=/mcp

# Manual sync rate limits (per account+project sliding window)
# SYNC_RATE_LIMIT_FREE_MAX=10
# SYNC_RATE_LIMIT_FREE_WINDOW_SECONDS=3600
# SYNC_RATE_LIMIT_PRO_MAX=60
# SYNC_RATE_LIMIT_PRO_WINDOW_SECONDS=3600

# Internal Pro bypass (comma-separated). Matches Account.login (case-insensitive) or github_id.
# INTERNAL_PRO_GITHUB_LOGINS=
# INTERNAL_PRO_GITHUB_IDS=
