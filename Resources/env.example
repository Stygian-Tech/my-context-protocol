# Database (Supabase or local Postgres)
# Option 1: Full URL (Supabase: use connection string from project settings)
# DATABASE_URL=postgres://user:password@host:5432/database

# Option 2: Supabase-style (if using SUPABASE_DB_URL)
# SUPABASE_DB_URL=postgres://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Option 3: Individual fields (local dev)
# DATABASE_HOST=localhost
# DATABASE_USERNAME=vapor_username
# DATABASE_PASSWORD=vapor_password
# DATABASE_NAME=vapor_database
# DATABASE_PORT=5432

# CORS (frontend origin for credentials)
CORS_ORIGIN=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# SaaS: webhook creation (base URL for webhook delivery, e.g. https://api.example.com)
WEBHOOK_BASE_URL=http://localhost:8080

# SaaS: token encryption (32 bytes base64; generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Optional fallback for repo fetch when no OAuth token (deprecated for SaaS)
# GITHUB_TOKEN=
