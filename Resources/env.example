# Database (Supabase or local Postgres)
# Option 1: Full URL (Supabase: use connection string from project settings)
# DATABASE_URL=postgres://user:password@host:5432/database

# Option 2: Supabase-style (if using SUPABASE_DB_URL)
# SUPABASE_DB_URL=postgres://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Option 3: Individual fields (local dev)
# DATABASE_HOST=localhost

# Dev only: skip TLS cert verification (e.g. Supabase on macOS with cert issues)
# DATABASE_INSECURE_TLS=1
# DATABASE_USERNAME=vapor_username
# DATABASE_PASSWORD=vapor_password
# DATABASE_NAME=vapor_database
# DATABASE_PORT=5432

# Deployment tier: local | dev | prod (unset or invalid defaults to prod)
APP_ENV=local
# Set to 1 on shared dev hosts to use real Pro gating (Stripe + INTERNAL_PRO_*) without env-wide Pro bypass
# STRICT_PRO_GATING=1

# CORS (frontend origin for credentials)
CORS_ORIGIN=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# GitHub App (Phase 2: installation tokens for Pro repo webhooks). See Docs/GITHUB_APP_ENV.md
# GITHUB_APP_CLIENT_ID=Iv1.              # App "Client ID" (JWT iss)
# GITHUB_APP_PRIVATE_KEY=               # PEM multiline, or use GITHUB_APP_PRIVATE_KEY_BASE64
# GITHUB_APP_PRIVATE_KEY_BASE64=
# GITHUB_APP_SLUG=my-app                # URL slug for https://github.com/apps/<slug>/installations/new
# GITHUB_APP_WEBHOOK_SECRET=            # Optional: enables POST /webhooks/github-app for install/revoke events
# Setup URL in GitHub App settings should be: http://localhost:8080/auth/github/app/callback (prod: https://api.../auth/github/app/callback)

# SaaS: webhook creation (base URL for webhook delivery, e.g. https://api.example.com)
WEBHOOK_BASE_URL=http://localhost:8080

# SaaS: token encryption (32 bytes base64; generate with: openssl rand -base64 32)
ENCRYPTION_KEY=

# Optional fallback for repo fetch when no OAuth token (deprecated for SaaS)
# GITHUB_TOKEN=

# Stripe (Pro billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly and yearly Price IDs (Products → Prices in Stripe Dashboard)
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_YEARLY=price_...
# Optional legacy: used as monthly if STRIPE_PRICE_PRO_MONTHLY is unset
# STRIPE_PRICE_PRO=price_...

# Checkout / portal success URLs use CORS_ORIGIN unless set:
# FRONTEND_URL=https://app.example.com

# MCP tenant host: requests to {subdomain}.{SAAS_MCP_BASE_DOMAIN} resolve project for API key binding
# SAAS_MCP_BASE_DOMAIN=mcp.example.com
#
# Public MCP URL in Project JSON (`mcp_url`): {SAAS_MCP_URL_SCHEME}://{host}{SAAS_MCP_PATH}
# SAAS_MCP_URL_SCHEME=https
# SAAS_MCP_PATH=/mcp

# Manual sync rate limits (per account+project sliding window)
# SYNC_RATE_LIMIT_FREE_MAX=10
# SYNC_RATE_LIMIT_FREE_WINDOW_SECONDS=3600
# SYNC_RATE_LIMIT_PRO_MAX=60
# SYNC_RATE_LIMIT_PRO_WINDOW_SECONDS=3600

# Internal Pro bypass (no Stripe). Comma-separated GitHub logins and/or numeric github_id values.
# INTERNAL_PRO_GITHUB_LOGINS=octocat,copilot
# INTERNAL_PRO_GITHUB_IDS=12345,67890
