# Database (Supabase or local Postgres)
# Option 1: Full URL (Supabase: use connection string from project settings)
# DATABASE_URL=postgres://user:password@host:5432/database

# Option 2: Supabase-style (if using SUPABASE_DB_URL)
# SUPABASE_DB_URL=postgres://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Option 3: Individual fields (local dev)
# DATABASE_HOST=localhost
# DATABASE_USERNAME=vapor_username
# DATABASE_PASSWORD=vapor_password
# DATABASE_NAME=vapor_database
# DATABASE_PORT=5432

# GitHub
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main

# Project
PROJECT_SLUG=my-skills

# Auth
WEBHOOK_SECRET=
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
