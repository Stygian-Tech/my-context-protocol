{
  "name": "my-context-protocol-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.30",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
