# Backend API base URL (Vapor server)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Matches backend APP_ENV: local | dev | prod (build-time; used for environment banner)
NEXT_PUBLIC_APP_ENV=local

# Frontend origin (OAuth return_to, Stripe redirects; optional — defaults to window.location.origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP endpoint URL is returned as `mcp_url` on each Project from the API (configure SAAS_MCP_* on the backend).
