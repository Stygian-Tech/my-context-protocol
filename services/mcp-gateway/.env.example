# =============================================================================
# MyContextProtocol API — all env vars read by Sources/App (see configure.swift
# and grep for Environment.get). Copy to .env and fill in secrets.
# =============================================================================

# --- Deployment (AppEnvironment.swift) ---
# local | dev | prod — empty or unknown defaults to prod (fail closed)
# APP_ENV=prod
# Strict Stripe/Pro gating: dev/prod default ON; local default OFF. Override: 1/true/yes or 0/false/no.
# STRICT_PRO_GATING=

# --- Local demo DB seed ---
# Creates demo projects, catalog rows, and ~3k request logs (~400d of skewed history) for dashboard charts.
# Runs when APP_ENV=local, or when APP_ENV is dev (non-prod) and USE_SQLITE=1 (file db — never targets shared Postgres).
# Idempotent: re-runs top up fixtures (e.g. mock failed release) without duplicating the ready release; wipe db.sqlite to fully reset.
# Sign in with GitHub once so an account row exists, then restart with SEED_LOCAL_FIXTURES=1.
# APP_ENV=local
# SEED_LOCAL_FIXTURES=1

# --- Dev logging (non-production only: APP_ENV=local or dev) ---
# One-line http_access … after each response (non-prod default on; stacks with DEV_LOG_HTTP req_* lines). Prod: HTTP_ACCESS_LOG=1.
# HTTP_ACCESS_LOG=0
# Verbose HTTP tracing is ON by default for local/dev. Set 0/false/no to turn off.
# DEV_LOG_HTTP=0
# MCP JSON-RPC per-handler traces at info. ON by default for local/dev. Set 0/false/no to turn off.
# DEV_LOG_MCP=0
# Fluent driver SQL logging at debug — ON by default for local/dev. Set 0/false/no to turn off.
# DEV_LOG_SQL=0
# SwiftLog level. When unset in non-production, defaults to debug (SQL + verbose HTTP). MCP lines are info regardless. Use LOG_LEVEL=info to reduce noise.
# LOG_LEVEL=info

# --- Database (configure.swift + DatabaseBootstrap.swift) ---
# Local file SQLite: set USE_SQLITE=1 and leave DATABASE_URL / SUPABASE_DB_URL empty
USE_SQLITE=1
# SQLITE_PATH=db.sqlite

# Postgres — full URL (preferred when not using SQLite)
DATABASE_URL=
# Alternative connection string name (checked after DATABASE_URL)
# SUPABASE_DB_URL=

# Individual Postgres fields (used when DATABASE_URL and SUPABASE_DB_URL are unset)
# APP_ENV=local: missing fields default to localhost / vapor_* (bare-metal local Postgres).
# APP_ENV=dev or APP_ENV=prod: all of HOST, USERNAME, PASSWORD, NAME must be set (non-empty); optional DATABASE_PORT defaults to 5432.
# No silent localhost fallback in dev/prod — avoids container crash loops connecting to 127.0.0.1:5432 inside the container.
# DATABASE_HOST=localhost
# DATABASE_USERNAME=vapor_username
# DATABASE_PASSWORD=vapor_password
# DATABASE_NAME=vapor_database
# DATABASE_PORT=5432

# Dev only: skip TLS cert verification (e.g. Supabase on macOS cert issues). 1/true.
# APP_ENV=prod rejects this setting and requires verified Postgres TLS.
DATABASE_INSECURE_TLS=

# Optional managed-Postgres CA bundle for verified TLS when the provider CA is not in the OS trust store.
# Prefer DATABASE_SSLROOTCERT_BASE64 or DATABASE_SSLROOTCERT_PEM as Fly secrets for Supabase CA bundles.
# DATABASE_SSLROOTCERT=/etc/ssl/certs/supabase-ca.pem
# DATABASE_SSLROOTCERT_PEM="-----BEGIN CERTIFICATE-----..."
# DATABASE_SSLROOTCERT_BASE64=

# Integration tests: use real Postgres from DATABASE_URL / SUPABASE_DB_URL instead of in-memory SQLite
# TEST_USE_POSTGRES=

# --- Docker Compose (docker-compose.yml) ---
# Local: a project `.env` next to `docker-compose.yml` is loaded by Compose for variable substitution only.
# Values are passed into the container only for names listed under `environment:` (no `env_file` in the repo compose file).
# Portainer: stack “Environment” variables are NOT injected into the container unless listed in compose
# `environment:` — the repo file already forwards the app’s variables; define them in Portainer with the
# same names (e.g. DATABASE_URL, SUPABASE_DB_URL, ENCRYPTION_KEY, APP_ENV).
# Image tag: `${APP_ENV}` must be set in stack env (or `.env`); CI publishes `…:dev` and `…:prod`.
# Container prod/dev: set USE_SQLITE=0 (or unset) and DATABASE_URL or SUPABASE_DB_URL (recommended), or all discrete DATABASE_* vars.
# Dev-only optional: DATABASE_INSECURE_TLS=1 for temporary managed Postgres TLS setup issues. Production rejects it.
# Production Supabase: keep DATABASE_INSECURE_TLS empty/0 and set DATABASE_SSLROOTCERT_PEM or DATABASE_SSLROOTCERT_BASE64 from the Supabase database CA bundle if certificate verification fails.

# --- HTTP: CORS, frontend URLs, session cookie (configure.swift, AppFrontendURL.swift) ---
# Browser origin for credentialed requests (required for production browser clients)
CORS_ORIGIN=http://localhost:3000
# Public app URL (no trailing slash). Billing/OAuth defaults; used with FRONTEND_URL for return_to validation
# FRONTEND_URL=http://localhost:3000

# When API and app use different hosts, set registrable domain so session works on both (e.g. GitHub App callback)
# SESSION_COOKIE_DOMAIN=.mycontextprotocol.dev

# --- Security / sessions (hardening) ---
# 1/true forces in-memory sessions (tests/single-instance only). Default: Fluent DB-backed sessions.
# USE_MEMORY_SESSIONS=
# In dev, 1/true requires MCP requests to hit tenant subdomain or verified custom domain (always on in prod).
# REQUIRE_MCP_TENANT_HOST=
# Per-minute MCP rate limit per client IP (in-process; use edge limits in production). Default 300.
# MCP_RATE_LIMIT_PER_MINUTE=300
# In dev, enable MCP rate limiting (enabled automatically when APP_ENV=prod).
# RATE_LIMIT_MCP_ENABLED=
# When 1/true, trust first X-Forwarded-For hop for MCP rate limiting (only behind a trusted proxy).
# TRUST_X_FORWARDED_FOR=
# Max GitHub tarball download size in MiB (default 150).
# REPO_TARBALL_MAX_MB=
# Max SKILL.md files scanned per repo (default 5000).
# REPO_MAX_SKILL_FILES=

# --- MCP OAuth (tenant host: discovery, /authorize, /oauth/consent, /token) ---
# 1/true enables OAuth on each project MCP hostname alongside API keys. Default off when unset.
# MCP_OAUTH_ENABLED=1
# Optional TTL overrides (seconds).
# MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# MCP_OAUTH_CODE_TTL_SECONDS=600
# MCP_OAUTH_PENDING_TTL_SECONDS=900
# When the API host differs from FRONTEND_URL, set this to the absolute origin of the Vapor API server
# (no trailing slash). Used for GitHub OAuth resume links AND automatically allowed as a return_to base —
# you do NOT need to set MCP_OAUTH_RESUME_BASE_URLS separately.
# MCP_OAUTH_API_ORIGIN=https://api.example.com
# Extra allowed return_to bases (comma-separated, no trailing slash). MCP_OAUTH_API_ORIGIN already covers
# the common case; only needed if additional API origins must be whitelisted.
# MCP_OAUTH_RESUME_BASE_URLS=https://alt-api.example.com
# Custom MCP domains behind TLS termination: when the proxy sets X-Forwarded-Host to the public hostname, enable (trusted edge only).
# MCP_TRUST_X_FORWARDED_HOST=1

# --- GitHub OAuth (AuthController) ---
# Browser login callback. When misconfigured (e.g. pointed at /auth/github/app/callback), the server
# derives the login URL from WEBHOOK_BASE_URL + /auth/github/callback instead.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# --- GitHub App — installation tokens & install flow (GitHubAppController, GitHubAppInstallationTokenService, ProjectController, AuthController) ---
# Not the same as GITHUB_CLIENT_ID (that is the OAuth app for login).
# GITHUB_APP_CLIENT_ID=Iv1...
# GITHUB_APP_CLIENT_SECRET=             # GitHub App “Client secrets” — required to exchange install OAuth `code` (user-to-server token)
# GITHUB_APP_SETUP_CALLBACK_URL=        # Must match User authorization callback URL (and Setup URL if used), e.g. https://app…/api/auth/github/app/callback
# GITHUB_APP_PRIVATE_KEY=               # Multiline PEM; often broken in Docker — prefer BASE64 below
# GITHUB_APP_PRIVATE_KEY_BASE64=        # base64 -i github-app.pem | tr -d '\n'  (single line, no newlines in env)
# GITHUB_APP_SLUG=my-app
# GITHUB_APP_WEBHOOK_SECRET=
# GitHub App env (Setup URL → app origin + /api/auth/github/app/callback when using Next.js); see team-internal setup docs.

# --- Webhooks & crypto ---
# Base URL for repo webhooks GitHub POSTs to (e.g. https://api.example.com)
WEBHOOK_BASE_URL=http://localhost:8080
# 32-byte key, base64 (openssl rand -base64 32) — OAuth/App signed state, token encryption
ENCRYPTION_KEY=

# --- Optional: anonymous repo fetch when no user OAuth token (RepoFetcher, TokenEncryption) ---
# GITHUB_TOKEN=

# --- Stripe (StripeClient, BillingController, StripeWebhookController) ---
# Set as Fly secrets (never in fly.toml): fly secrets set STRIPE_SECRET_KEY=sk_... STRIPE_WEBHOOK_SECRET=whsec_...
#
# STRIPE_SECRET_KEY=sk_live_...          (or sk_test_... in dev/test)
# STRIPE_WEBHOOK_SECRET=whsec_...        (Stripe dashboard → Webhooks → signing secret)
# STRIPE_PRICE_PRO_MONTHLY=price_...     (monthly Pro price ID)
# STRIPE_PRICE_PRO_YEARLY=price_...      (yearly Pro price ID)
# STRIPE_PRICE_PRO=price_...             (legacy fallback if STRIPE_PRICE_PRO_MONTHLY unset)
#
# Stripe dashboard webhook endpoint:  POST https://<your-domain>/webhooks/stripe
# Subscribe to these events (and no others are required):
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated          (also covers invoice.payment_failed → status=past_due)
#   customer.subscription.deleted

# --- SaaS MCP host & public MCP URL (TenantHostMiddleware, McpUrlBuilder) ---
# Tenant host: {subdomain}.{SAAS_MCP_BASE_DOMAIN}
# SAAS_MCP_BASE_DOMAIN=mcp.example.com
# SAAS_MCP_URL_SCHEME=https
# SAAS_MCP_PATH=/mcp

# --- Tier limits ---
# FREE_PROJECT_LIMIT=1                    (default: 1; max projects for free-tier accounts)
# PRO_PROJECT_LIMIT=5                     (default: 5; max projects for Pro accounts)
#
# --- Manual sync rate limits (ProjectController + SyncRateLimiter) ---
# SYNC_RATE_LIMIT_FREE_MAX=10
# SYNC_RATE_LIMIT_FREE_WINDOW_SECONDS=3600
# SYNC_RATE_LIMIT_PRO_MAX=60
# SYNC_RATE_LIMIT_PRO_WINDOW_SECONDS=3600

# --- Internal Pro bypass — comma-separated (InternalProBypass) ---
# INTERNAL_PRO_GITHUB_LOGINS=
# INTERNAL_PRO_GITHUB_IDS=

# First platform admins (comma-separated GitHub logins / numeric ids). Persisted to DB on /auth/GITHUB callback or GET /me.
# Keep secrets in a host `.env` for Compose substitution, or define them in Portainer — they must still appear under `environment:` in compose to reach the container.
# INTERNAL_ADMIN_GITHUB_LOGINS=
# INTERNAL_ADMIN_GITHUB_IDS=

# --- Admin hourly analytics rollup (optional) ---
# Charts on GET /admin/timeseries read table `admin_analytics_hourly`.
# The server runs a full refresh on boot (after migrations), then every hour (including Vapor --env testing).
# Disable in-process scheduler (e.g. swift test / CI, or external-only cron):
# DISABLE_ADMIN_ANALYTICS_ROLLUP_SCHEDULER=1
# Refresh manually: POST /admin/analytics/rollup-refresh (admin session). Extra context: team-internal docs.
