# =============================================================================
# MyContextProtocol API — all env vars read by Sources/App (see root .env.example).
# Copy alongside the binary or use with Docker / process manager.
# Docker Compose (repo root): runs the API only; see root `.env.example` for full list + how `environment:` pass-through works.
# =============================================================================

# --- Deployment (AppEnvironment.swift) ---
# local | dev | prod — empty or unknown defaults to prod
APP_ENV=local
# Strict Stripe/Pro gating: dev/prod default ON; local default OFF. Override: 1/true/yes or 0/false/no.
# STRICT_PRO_GATING=

# --- Dev logging (APP_ENV=local|dev only) ---
# Verbose HTTP tracing on by default; DEV_LOG_HTTP=0 to disable
# DEV_LOG_HTTP=0
# DEV_LOG_SQL=1
# LOG_LEVEL=debug

# --- Database (configure.swift + DatabaseBootstrap.swift) ---
# USE_SQLITE=1
# SQLITE_PATH=db.sqlite
# DATABASE_URL=postgres://user:password@host:5432/database
# SUPABASE_DB_URL=postgres://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres
# DATABASE_INSECURE_TLS=1
# APP_ENV=local: discrete fields default to localhost / vapor_* when unset.
# APP_ENV=dev|prod: set DATABASE_URL/SUPABASE_DB_URL or all DATABASE_HOST/USERNAME/PASSWORD/NAME (non-empty).
# DATABASE_HOST=localhost
# DATABASE_USERNAME=vapor_username
# DATABASE_PASSWORD=vapor_password
# DATABASE_NAME=vapor_database
# DATABASE_PORT=5432
# TEST_USE_POSTGRES=1

# --- HTTP: CORS, frontend, session cookie ---
CORS_ORIGIN=http://localhost:3000
# FRONTEND_URL=http://localhost:3000
# USE_MEMORY_SESSIONS=1 — only for single-instance/test (default: DB-backed sessions)
# REQUIRE_MCP_TENANT_HOST=
# MCP_RATE_LIMIT_PER_MINUTE=300
# RATE_LIMIT_MCP_ENABLED=
# TRUST_X_FORWARDED_FOR=
# REPO_TARBALL_MAX_MB=150
# REPO_MAX_SKILL_FILES=5000
# SESSION_COOKIE_DOMAIN=.mycontextprotocol.dev

# --- GitHub OAuth (AuthController) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# --- GitHub App (GitHubAppController, GitHubAppInstallationTokenService, ProjectController, AuthController) ---
# GITHUB_APP_CLIENT_ID=Iv1...
# GITHUB_APP_CLIENT_SECRET=
# GITHUB_APP_SETUP_CALLBACK_URL=https://app.example.com/api/auth/github/app/callback
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_PRIVATE_KEY_BASE64=
# GITHUB_APP_SLUG=my-app
# GITHUB_APP_WEBHOOK_SECRET=

# --- Webhooks & crypto ---
WEBHOOK_BASE_URL=http://localhost:8080
ENCRYPTION_KEY=
# GITHUB_TOKEN=

# --- Stripe (StripeClient, BillingController, StripeWebhookController) ---
# Set as Fly secrets (never in fly.toml): fly secrets set STRIPE_SECRET_KEY=sk_... STRIPE_WEBHOOK_SECRET=whsec_...
#
# STRIPE_SECRET_KEY=sk_live_...          (or sk_test_... in dev/test)
# STRIPE_WEBHOOK_SECRET=whsec_...        (Stripe dashboard → Webhooks → signing secret)
# STRIPE_PRICE_PRO_MONTHLY=price_...     (monthly Pro price ID)
# STRIPE_PRICE_PRO_YEARLY=price_...      (yearly Pro price ID)
# STRIPE_PRICE_PRO=price_...             (legacy fallback if STRIPE_PRICE_PRO_MONTHLY unset)
#
# Stripe dashboard webhook endpoint:  POST https://<your-domain>/webhooks/stripe
# Subscribe to these events:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated          (also covers invoice.payment_failed → status=past_due)
#   customer.subscription.deleted

# --- SaaS MCP (TenantHostMiddleware, McpUrlBuilder) ---
# SAAS_MCP_BASE_DOMAIN=mcp.example.com
# SAAS_MCP_URL_SCHEME=https
# SAAS_MCP_PATH=/mcp
#
# MCP OAuth public DCR supports Claude-style authorization_code + PKCE clients only.
# It does not issue client secrets, refresh tokens, or client_credentials tokens.
#
# Optional Fly edge certificate provisioning for verified custom domains.
# Required in production if tenants use hostnames outside SAAS_MCP_BASE_DOMAIN.
# FLY_API_TOKEN=FlyV1...
# FLY_CERTIFICATE_APP_NAME=my-context-protocol-prod-gateway
# FLY_CERTIFICATE_API_BASE_URL=https://api.machines.dev

# --- Tier limits ---
# FREE_PROJECT_LIMIT=1                    (default: 1; max projects for free-tier accounts)
#
# --- Manual sync rate limits (ProjectController) ---
# SYNC_RATE_LIMIT_FREE_MAX=10
# SYNC_RATE_LIMIT_FREE_WINDOW_SECONDS=3600
# SYNC_RATE_LIMIT_PRO_MAX=60
# SYNC_RATE_LIMIT_PRO_WINDOW_SECONDS=3600

# --- Internal Pro bypass (InternalProBypass) ---
# INTERNAL_PRO_GITHUB_LOGINS=octocat
# INTERNAL_PRO_GITHUB_IDS=12345

# First platform admins (comma-separated); persisted to DB on login.
# INTERNAL_ADMIN_GITHUB_LOGINS=
# INTERNAL_ADMIN_GITHUB_IDS=
